{
  "entities": {
    "users": {
      "title": "User",
      "description": "User profile and approval status",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "isApproved": { "type": "boolean" },
        "role": { "type": "string", "enum": ["admin", "user"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "isApproved"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "users",
      "description": "User documents indexed by their UID"
    }
  }
}
