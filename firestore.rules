rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - uid: string (required)
    //   - email: string (required)
    //   - displayName: string (optional)
    //   - photoURL: string (optional)
    //   - isApproved: boolean (required)
    //   - role: string (required, ['admin', 'user'])
    //   - createdAt: timestamp (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && (
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
        (request.auth.token.email == "ahdanhqq1@gmail.com" && request.auth.token.email_verified == true)
      );
    }

    function isAdminEmail() {
      return isAuthenticated() && request.auth.token.email == "ahdanhqq1@gmail.com" && request.auth.token.email_verified == true;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'isApproved', 'role', 'createdAt']) &&
             data.uid is string &&
             data.email is string &&
             data.isApproved is bool &&
             data.role in ['admin', 'user'] &&
             data.createdAt is timestamp;
    }

    function isValidEnhancement(data) {
      return data.keys().hasAll(['id', 'userId', 'originalImageUrl', 'enhancedImageUrl', 'createdAt']) &&
             data.id is string &&
             data.userId is string &&
             data.originalImageUrl is string &&
             data.enhancedImageUrl is string &&
             data.createdAt is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      // Users can read their own data
      allow read: if isOwner(userId) || isAdmin();
      
      // Users can create their own initial profile
      // Admin email can create as approved admin
      allow create: if isOwner(userId) && 
                      isValidUser(request.resource.data) &&
                      (
                        (isAdminEmail() && request.resource.data.isApproved == true && request.resource.data.role == 'admin') ||
                        (request.resource.data.isApproved == false && request.resource.data.role == 'user')
                      );
      
      // Admin can update any user (e.g., to approve them)
      // Admin email can update its own profile to be admin/approved
      allow update: if (isAdmin() || (isOwner(userId) && isAdminEmail())) && isValidUser(request.resource.data);
    }

    match /enhancements/{enhancementId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.userId || isAdmin());
      allow create: if isAuthenticated() && 
                      request.auth.uid == request.resource.data.userId &&
                      isValidEnhancement(request.resource.data);
      allow update, delete: if isAuthenticated() && (request.auth.uid == resource.data.userId || isAdmin());
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
